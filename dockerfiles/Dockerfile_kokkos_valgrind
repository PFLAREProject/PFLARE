ARG BASE_IMAGE=stevendargaville/petsc_kokkos

FROM ${BASE_IMAGE}
# Use the optimised petsc build by default
ARG ARCH=arch-linux-c-opt
# Set the number of OpenMP threads to 1 by default
ARG OMP_NUM_THREADS=1

LABEL maintainer="Steven Dargaville"
LABEL description="PFLARE_kokkos_valgrind"

ENV PETSC_ARCH=$ARCH
ENV OMP_NUM_THREADS=$OMP_NUM_THREADS
# This turns on checks between kokkos and cpu versions
ENV PFLARE_KOKKOS_DEBUG=1
# -on_error_abort ensures any test failures are caught and the build fails
ENV PETSC_OPTIONS="-mat_type aijkokkos -vec_type kokkos -dm_mat_type aijkokkos -dm_vec_type kokkos -on_error_abort"

WORKDIR /build

COPY . /build/PFLARE

# Ensure pipelines fail if any stage fails
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Build PFLARE with -O0 -g for debuggable valgrind output (the underlying petsc_kokkos image
# is built with optimisation on, so we override here for PFLARE itself) and run tests_short
# with valgrind --leak-check=full
# Inject valgrind into test invocations via sed:
#   - Serial tests:   <tab>./executable -> <tab>valgrind ... ./executable
#   - Parallel tests: $(MPIEXEC) -n N ./executable -> $(MPIEXEC) -n N valgrind ... ./executable
# --error-exitcode=1 causes valgrind to return non-zero on errors or leaks
# --errors-for-leak-kinds=definite,indirect ensures definitely/indirectly lost memory is treated as an error
RUN set -euo pipefail; \
    cd PFLARE && \
    make clean && \
    make -j2 CFLAGS="-O0 -g" CXXFLAGS="-O0 -g -std=c++20" CPPFLAGS="-O0 -g" FFLAGS="-O0 -g" build_tests && \
    sed -i 's|\t\./|\tvalgrind --leak-check=full --error-exitcode=1 --errors-for-leak-kinds=definite,indirect \./|g' tests/Makefile && \
    sed -i 's|\$(MPIEXEC) -n \([0-9]*\) \./|\$(MPIEXEC) -n \1 valgrind --leak-check=full --error-exitcode=1 --errors-for-leak-kinds=definite,indirect \./|g' tests/Makefile && \
    make tests_short

WORKDIR /build/PFLARE
